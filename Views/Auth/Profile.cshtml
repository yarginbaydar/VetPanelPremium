@model VetPanelPremium.Models.AdminUser
@{ ViewData["Title"] = "Profilimi Düzenle"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="premium-card p-5 border-top border-primary border-4 shadow-sm mt-4">
            
            <div class="text-center mb-4">
                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm border border-2 border-white" style="width: 80px; height: 80px;">
                    <i class="bi bi-person-badge fs-1"></i>
                </div>
                <h3 class="fw-bold text-dark">Başhekim Profili</h3>
                <p class="text-muted small">Giriş bilgilerinizi ve şifrenizi buradan güncelleyebilirsiniz.</p>
            </div>

            <form asp-action="Profile" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Role" />

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-bold text-secondary">Görünen Adınız</label>
                    <input asp-for="FullName" class="form-control bg-light border-0 shadow-none form-control-lg" required />
                    <small class="text-muted">Sağ üst menüde yazan isimdir.</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label fw-bold text-secondary">Kullanıcı Adı</label>
                    <div class="input-group input-group-lg">
                        <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-person-fill"></i></span>
                        <input asp-for="Username" class="form-control bg-light border-0 shadow-none" required />
                    </div>
                </div>

                <div class="mb-5">
                    <label asp-for="Password" class="form-label fw-bold text-danger">Yeni Şifre Belirle <i class="bi bi-lock-fill"></i></label>
                    <input asp-for="Password" type="text" class="form-control bg-light border-0 shadow-none form-control-lg border-start border-danger border-4" required />
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm rounded-pill">
                        <i class="bi bi-save2 me-2"></i> Profilimi Güncelle
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>