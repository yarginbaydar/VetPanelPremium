@model VetPanelPremium.Models.ClinicSetting
@{ ViewData["Title"] = "Klinik Sistem Ayarları"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="bi bi-gear-fill text-secondary me-2"></i> Klinik Ayarları</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 border-start border-success border-4 mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2 fs-5"></i> <strong>Başarılı!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="premium-card p-4 border-top border-secondary border-4 h-100 text-center">
            <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="bi bi-hospital fs-1"></i>
            </div>
            <h4 class="fw-bold text-dark mb-1">VetPanel Premium</h4>
            <p class="text-muted small">Sistem Konfigürasyonu</p>
            <hr class="text-muted my-4" />
            <div class="text-start">
                <p class="small text-muted mb-2"><i class="bi bi-info-circle me-1"></i> Bu sayfada girdiğiniz bilgiler;</p>
                <ul class="small text-secondary text-start">
                    <li>Müşteri Faturalarında</li>
                    <li>Reçete Çıktılarında</li>
                    <li>Randevu Hatırlatmalarında</li>
                </ul>
                <p class="small text-muted mt-2">otomatik olarak kullanılacaktır. Lütfen bilgileri eksiksiz doldurun.</p>
            </div>
        </div>
    </div>

    <div class="col-md-8 mb-4">
        <div class="premium-card p-4 border-top border-primary border-4 shadow-sm">
            <h5 class="fw-bold text-dark mb-4"><i class="bi bi-building me-2 text-primary"></i> Temel Bilgiler</h5>
            
            <form asp-action="Index" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row mb-3">
                    <div class="col-md-12">
                        <label asp-for="ClinicName" class="form-label fw-bold text-secondary">Resmi Klinik Adı <span class="text-danger">*</span></label>
                        <input asp-for="ClinicName" class="form-control form-control-lg bg-light border-0 shadow-none border-start border-primary border-4" required />
                        <span asp-validation-for="ClinicName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label fw-bold text-secondary">İletişim Numarası</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-telephone"></i></span>
                            <input asp-for="PhoneNumber" class="form-control bg-light border-0 shadow-none" placeholder="Örn: 0212 555 44 33" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-bold text-secondary">E-Posta Adresi</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" type="email" class="form-control bg-light border-0 shadow-none" placeholder="iletisim@klinik.com" />
                        </div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="TaxNumber" class="form-label fw-bold text-secondary">Vergi Dairesi / VKN</label>
                        <input asp-for="TaxNumber" class="form-control bg-light border-0 shadow-none" placeholder="Mali işlemler için..." />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="WorkingHours" class="form-label fw-bold text-secondary">Çalışma Saatleri</label>
                        <input asp-for="WorkingHours" class="form-control bg-light border-0 shadow-none" placeholder="Örn: H.içi 09:00 - 19:00" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Address" class="form-label fw-bold text-secondary">Klinik Açık Adresi</label>
                    <textarea asp-for="Address" class="form-control bg-light border-0 shadow-none" rows="2" placeholder="Fatura ve iletişim adresi..."></textarea>
                </div>

                <hr class="text-muted mb-4" />

                <div class="text-end">
                    <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm rounded-pill">
                        <i class="bi bi-save2 me-1"></i> Ayarları Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}