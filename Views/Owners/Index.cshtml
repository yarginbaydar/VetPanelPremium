@model IEnumerable<VetPanelPremium.Models.Owner>
@{ ViewData["Title"] = "Müşteri Portföyü (CRM)"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="bi bi-people text-primary me-2"></i> Müşteri Portföyü</h2>
    <a asp-action="Create" class="btn btn-primary px-4 fw-bold shadow-sm rounded-pill">
        <i class="bi bi-person-plus-fill me-1"></i> Yeni Müşteri Ekle
    </a>
</div>

<div class="premium-card p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="text-secondary py-3">Müşteri Bilgisi</th>
                    <th class="text-secondary py-3">İletişim & Adres</th>
                    <th class="text-secondary py-3">TC / VKN</th>
                    <th class="text-secondary py-3">Güncel Bakiye</th>
                    <th class="text-secondary py-3 text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3 text-primary opacity-50"></i>
                            <h5 class="fw-bold">Henüz Müşteri Kaydı Yok</h5>
                            <p>Klinik sisteminize ilk müşterinizi sağ üstteki butondan ekleyebilirsiniz.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr class="border-bottom">
                            <td class="fw-bold text-dark">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 me-3">
                                        <i class="bi bi-person-fill fs-5"></i>
                                    </div>
                                    @item.FullName
                                </div>
                            </td>
                            <td>
                                <i class="bi bi-telephone-fill text-success small me-1"></i> @item.PhoneNumber <br/>
                                <small class="text-muted"><i class="bi bi-geo-alt-fill small me-1"></i> @(string.IsNullOrEmpty(item.Address) ? "Adres Girilmemiş" : item.Address)</small>
                            </td>
                            <td>
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border">
                                    @(string.IsNullOrEmpty(item.IdentityNumber) ? "Belirtilmemiş" : item.IdentityNumber)
                                </span>
                            </td>
                            <td>
                                <h5 class="mb-0 text-@(item.DebtBalance > 0 ? "danger" : "success") fw-bold">
                                    @item.DebtBalance.ToString("C")
                                </h5>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center align-items-center gap-1">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light text-primary border shadow-sm fw-bold">
                                    <i class="bi bi-eye-fill"></i> Detay
                                    </a>
                                    
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-warning border shadow-sm fw-bold" title="Düzenle">
                                    <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id" 
                                       class="btn btn-sm btn-danger shadow-sm fw-bold ms-1" 
                                       onclick="return confirm('DİKKAT! Bu müşteriyi silerseniz, ona ait TÜM HASTALAR VE KAYITLAR da silinebilir! Emin misiniz?');" 
                                       title="Sistemden Sil">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>