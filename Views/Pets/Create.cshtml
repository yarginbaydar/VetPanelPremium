@model VetPanelPremium.Models.Pet
@{ ViewData["Title"] = "Yeni Hasta Kaydı"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="bi bi-box2-heart text-success me-2"></i> Yeni Hasta (Pet) Kaydı</h2>
    <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 fw-bold shadow-sm rounded-pill">
        <i class="bi bi-arrow-left me-1"></i> Geri Dön
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="premium-card p-5 border-top border-success border-4">
            
            <form asp-action="Create" enctype="multipart/form-data">
                
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4 p-3 bg-light rounded-3 border border-success border-opacity-25">
                    <label asp-for="OwnerId" class="form-label fw-bold text-dark">
                        <i class="bi bi-person-fill text-primary"></i> Hasta Sahibi (Müşteri) <span class="text-danger">*</span>
                    </label>
                    <select asp-for="OwnerId" class="form-select form-select-lg border-0 shadow-sm" asp-items="ViewBag.OwnerId" required>
                        <option value="">-- Müşteri Seçiniz --</option>
                    </select>
                    <span asp-validation-for="OwnerId" class="text-danger"></span>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold text-secondary">Pet Adı *</label>
                        <input asp-for="Name" class="form-control form-control-lg bg-light border-0 shadow-none" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Species" class="form-label fw-bold text-secondary">Türü *</label>
                        <select asp-for="Species" class="form-select form-select-lg bg-light border-0 shadow-none" required>
                            <option value="">-- Seçiniz --</option>
                            <option value="Kedi">🐱 Kedi</option>
                            <option value="Köpek">🐶 Köpek</option>
                            <option value="Kuş">🐦 Kuş</option>
                            <option value="Egzotik">🦎 Egzotik</option>
                        </select>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Breed" class="form-label fw-bold text-secondary">Irkı</label>
                        <input asp-for="Breed" class="form-control bg-light border-0 shadow-none" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Gender" class="form-label fw-bold text-secondary">Cinsiyet</label>
                        <select asp-for="Gender" class="form-select bg-light border-0 shadow-none">
                            <option value="">-- Seçiniz --</option>
                            <option value="Erkek">Erkek</option>
                            <option value="Dişi">Dişi</option>
                        </select>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-4">
                        <label asp-for="Weight" class="form-label fw-bold text-secondary">Kilo</label>
                        <input asp-for="Weight" type="number" step="0.1" class="form-control bg-light border-0 shadow-none" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="BirthDate" class="form-label fw-bold text-secondary">Doğum Tarihi</label>
                        <input asp-for="BirthDate" type="date" class="form-control bg-light border-0 shadow-none" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ChipNumber" class="form-label fw-bold text-secondary">Mikroçip No</label>
                        <input asp-for="ChipNumber" class="form-control bg-light border-0 shadow-none" />
                    </div>
                </div>

                <div class="mb-5 p-3 border border-2 border-dashed rounded bg-light">
                    <label asp-for="TahlilDosyasi" class="form-label fw-bold text-primary">
                        <i class="bi bi-file-earmark-medical"></i> İlk Muayene Röntgeni / Tahlil Yükle (İsteğe Bağlı)
                    </label>
                    <input asp-for="TahlilDosyasi" type="file" class="form-control shadow-none" accept=".pdf,.jpg,.jpeg,.png" />
                    <small class="text-muted mt-1 d-block">Sadece PDF veya Resim formatında yükleme yapabilirsiniz.</small>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success btn-lg fw-bold shadow-sm rounded-pill">
                        <i class="bi bi-save me-2"></i> Hastayı Sisteme Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}