@model IEnumerable<VetPanelPremium.Models.Pet> 
@{ ViewData["Title"] = "Hasta Kayıtları (EMR)"; } 

<div class="d-flex justify-content-between align-items-center mb-4"> 
    <h2 class="fw-bold text-dark"><i class="bi bi-box2-heart text-success me-2"></i> Tüm Hastalar (Petler)</h2> 
    <a asp-action="Create" class="btn btn-success px-4 fw-bold shadow-sm rounded-pill"> 
        <i class="bi bi-plus-lg me-1"></i> Yeni Hasta Kaydı 
    </a> 
</div> 

<div class="row mb-4">
    <div class="col-md-12">
        <form asp-action="Index" method="get">
            <div class="input-group input-group-lg shadow-sm rounded-pill overflow-hidden border border-success border-opacity-50">
                <span class="input-group-text bg-white border-0 text-success"><i class="bi bi-search"></i></span>
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-0 shadow-none" placeholder="Pet Adı, Türü, Irkı, Çip No veya Sahip Adı ile hızlıca ara..." />
                <button type="submit" class="btn btn-success fw-bold px-4 border-0">Arama Yap</button>
                <a asp-action="Index" class="btn btn-light text-secondary fw-bold px-4 border-start">Temizle</a>
            </div>
        </form>
    </div>
</div>

<div class="premium-card p-4 border-top border-success border-4"> 
    <div class="table-responsive"> 
        <table class="table table-hover align-middle mb-0"> 
            <thead class="table-light"> 
                <tr> 
                    <th class="text-secondary py-3">Hasta Bilgisi</th> 
                    <th class="text-secondary py-3">Tür / Irk / Cinsiyet</th> 
                    <th class="text-secondary py-3">Sahibi</th> 
                    <th class="text-secondary py-3 text-center">Fiziksel Özellik</th> 
                    <th class="text-secondary py-3 text-center">İşlemler</th> 
                </tr> 
            </thead> 
            <tbody> 
                @if (!Model.Any()) 
                { 
                    <tr> 
                        <td colspan="5" class="text-center py-5 text-muted"> 
                            <i class="bi bi-search-heart fs-1 d-block mb-3 text-success opacity-50"></i> 
                            <h5 class="fw-bold">Aradığınız Kriterlerde Hasta Bulunamadı</h5> 
                            <p>Farklı bir isim veya tür yazarak tekrar deneyin.</p> 
                        </td> 
                    </tr> 
                } 
                else 
                { 
                    @foreach (var item in Model) 
                    { 
                        // Türüne göre emoji mantığı 
                        var avatar = "🐾"; 
                        if (!string.IsNullOrEmpty(item.Species)) 
                        { 
                            var speciesLower = item.Species.ToLower(); 
                            if (speciesLower.Contains("kedi")) avatar = "🐱"; 
                            else if (speciesLower.Contains("köpek")) avatar = "🐶"; 
                            else if (speciesLower.Contains("kuş")) avatar = "🐦"; 
                            else if (speciesLower.Contains("egzotik")) avatar = "🦎"; 
                        } 
                        
                        <tr class="border-bottom"> 
                            <td class="fw-bold text-dark"> 
                                <div class="d-flex align-items-center"> 
                                    <div class="fs-2 me-3 bg-light rounded-circle d-flex align-items-center justify-content-center border shadow-sm" style="width: 50px; height: 50px;"> 
                                        @avatar 
                                    </div> 
                                    <div> 
                                        <span class="d-block fs-5">@item.Name</span> 
                                    </div> 
                                </div> 
                            </td> 
                            <td> 
                                <span class="fw-bold text-secondary">@item.Species</span> <br/> 
                                <small class="text-muted"> 
                                    @(string.IsNullOrEmpty(item.Breed) ? "Irk Belirtilmemiş" : item.Breed) | 
                                    <i class="bi bi-gender-ambiguous"></i> @(string.IsNullOrEmpty(item.Gender) ? "-" : item.Gender) 
                                </small> 
                            </td> 
                            <td> 
                                @if(item.Owner != null) 
                                { 
                                    <a asp-controller="Owners" asp-action="Details" asp-route-id="@item.OwnerId" class="text-decoration-none fw-bold text-primary"> 
                                        <i class="bi bi-person-fill"></i> @item.Owner.FullName 
                                    </a> 
                                    <br /> 
                                    <small class="text-muted"><i class="bi bi-telephone"></i> @item.Owner.PhoneNumber</small> 
                                } 
                                else 
                                { 
                                    <span class="text-danger">Sahibi Yok</span> 
                                } 
                            </td> 
                            <td class="text-center"> 
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border shadow-sm"> 
                                    <i class="bi bi-speedometer2"></i> @(item.Weight != null ? item.Weight + " kg" : "Kilo Yok") 
                                </span> 
                            </td> 
                            <td class="text-center"> 
                                <div class="d-flex justify-content-center align-items-center gap-2"> 
                                    @if (!string.IsNullOrEmpty(item.TahlilDosyaYolu)) 
                                    { 
                                        <a href="@item.TahlilDosyaYolu" target="_blank" class="btn btn-sm btn-info text-white shadow-sm fw-bold" title="Röntgen/Tahlil Görüntüle"> 
                                            <i class="bi bi-file-earmark-medical"></i> Tahlil 
                                        </a> 
                                    } 
                                    <a asp-controller="MedicalRecords" asp-action="Index" asp-route-petId="@item.Id" class="btn btn-sm btn-success shadow-sm fw-bold"> 
                                        <i class="bi bi-journal-medical"></i> Tıbbi Dosya 
                                    </a> 
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light text-warning border shadow-sm fw-bold" title="Düzenle"> 
                                        <i class="bi bi-pencil-square"></i> 
                                    </a> 
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger shadow-sm fw-bold ms-1" onclick="return confirm('DİKKAT! Bu hastayı silmek istediğinize emin misiniz? Geri dönüşü yoktur!');" title="Sistemden Sil"> 
                                        <i class="bi bi-trash3-fill"></i> 
                                    </a> 
                                </div> 
                            </td> 
                        </tr> 
                    } 
                } 
            </tbody> 
        </table> 
    </div> 
</div>