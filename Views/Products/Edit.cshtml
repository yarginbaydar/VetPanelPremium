@model VetPanelPremium.Models.Product
@{ ViewData["Title"] = "Ürün / Hizmet Düzenle"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="bi bi-pencil-square text-warning me-2"></i> Ürün/Hizmet Düzenle</h2>
    <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold shadow-sm rounded-pill">
        <i class="bi bi-arrow-left me-1"></i> Depoya Dön
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="premium-card p-5 border-top border-warning border-4 shadow-sm">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm rounded-3 mb-3"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="IsActive" />

                <div class="row mb-4">
                    <div class="col-md-8">
                        <label asp-for="Name" class="form-label fw-bold text-secondary">Ürün / Hizmet Adı <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control form-control-lg bg-light border-0 shadow-sm" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mt-3 mt-md-0">
                        <label asp-for="Category" class="form-label fw-bold text-secondary">Kategori <span class="text-danger">*</span></label>
                        <select asp-for="Category" class="form-select form-select-lg bg-light border-0 shadow-sm" required>
                            <option value="Hizmet">🩺 Hizmet / Muayene</option>
                            <option value="Aşı">💉 Aşı / İlaç</option>
                            <option value="Mama">🥩 Mama / Konserve</option>
                            <option value="Aksesuar">🧸 Aksesuar / Oyuncak</option>
                            <option value="Diğer">📦 Diğer</option>
                        </select>
                        <span asp-validation-for="Category" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Barcode" class="form-label fw-bold text-secondary">Barkod</label>
                        <input asp-for="Barcode" class="form-control bg-light border-0 shadow-sm" />
                    </div>
                    <div class="col-md-6 mt-3 mt-md-0">
                        <label asp-for="StockQuantity" class="form-label fw-bold text-secondary">Stok Adedi</label>
                        <input asp-for="StockQuantity" type="number" class="form-control bg-light border-0 shadow-sm border-start border-warning border-4" />
                    </div>
                </div>

                <div class="row mb-5">
                    <div class="col-md-4">
                        <label asp-for="PurchasePrice" class="form-label fw-bold text-secondary">Alış Fiyatı (₺)</label>
                        <input asp-for="PurchasePrice" type="number" step="0.01" class="form-control bg-light border-0 shadow-sm" />
                    </div>
                    <div class="col-md-4 mt-3 mt-md-0">
                        <label asp-for="SalePrice" class="form-label fw-bold text-success">Satış Fiyatı (₺) <span class="text-danger">*</span></label>
                        <input asp-for="SalePrice" type="number" step="0.01" class="form-control form-control-lg bg-light border-0 shadow-sm border-start border-success border-4" required />
                        <span asp-validation-for="SalePrice" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mt-3 mt-md-0">
                        <label asp-for="ExpirationDate" class="form-label fw-bold text-danger">Son Kullanma Tarihi (SKT)</label>
                        <input asp-for="ExpirationDate" type="date" class="form-control form-control-lg bg-light border-0 shadow-sm border-start border-danger border-4" />
                    </div>
                </div>

                <div class="d-grid gap-2 border-top pt-4">
                    <button type="submit" class="btn btn-warning btn-lg text-dark fw-bold shadow-sm rounded-pill">
                        <i class="bi bi-save me-2"></i> Değişiklikleri Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}