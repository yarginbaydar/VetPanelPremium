@model IEnumerable<VetPanelPremium.Models.Owner>
@{ ViewData["Title"] = "Veresiye Defteri"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark"><i class="bi bi-journal-minus text-danger me-2"></i> Veresiye Defteri (Alacaklar)</h2>
    <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold shadow-sm rounded-pill">
        <i class="bi bi-wallet2 me-1"></i> Kasaya Dön
    </a>
</div>

<div class="premium-card p-4 border-top border-danger border-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="text-secondary py-3">Müşteri Adı</th>
                    <th class="text-secondary py-3">Telefon</th>
                    <th class="text-secondary py-3 text-end">Toplam Borç Bakiyesi</th>
                    <th class="text-secondary py-3 text-center">Tahsilat İşlemi</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-emoji-smile fs-1 d-block mb-3 text-success opacity-50"></i>
                            <h5 class="fw-bold">Harika Haber!</h5>
                            <p>Şu an kliniğe borcu olan hiçbir müşteri bulunmuyor.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr class="border-bottom">
                            <td class="fw-bold text-dark"><i class="bi bi-person-fill text-muted me-2"></i> @item.FullName</td>
                            <td>@item.PhoneNumber</td>
                            <td class="text-end fw-bold text-danger fs-5">@item.DebtBalance.ToString("C")</td>
                            <td class="text-center">
                                
                                <form asp-action="PayDebt" method="post" class="d-flex justify-content-center align-items-center" onsubmit="return checkOverpayment(this, @item.DebtBalance.ToString("F2").Replace(",", "."));">
                                    <input type="hidden" name="ownerId" value="@item.Id" />
                                    <div class="input-group input-group-sm" style="max-width: 200px;">
                                        
                                        <input type="number" name="amount" class="form-control" step="0.01" placeholder="Tutar girin..." required />
                                        
                                        <button type="submit" class="btn btn-success fw-bold">
                                            <i class="bi bi-cash-coin"></i> Al
                                        </button>
                                    </div>
                                </form>

                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function checkOverpayment(form, maxDebt) {
            // Kutunun içine yazılan parayı alıyoruz
            var enteredAmount = parseFloat(form.querySelector('input[name="amount"]').value);
            
            // Eğer yazılan para, adamın borcundan büyükse Pop-up fırlat!
            if (enteredAmount > maxDebt) {
                alert("⚠️ KASA UYARISI!\n\nMüşterinin toplam borcu: " + maxDebt + " ₺\nGirilen tahsilat tutarı: " + enteredAmount + " ₺\n\nBorçtan daha fazla tahsilat yapamazsınız. Lütfen tutarı düzeltin.");
                
                // Formun gönderilmesini (sayfanın yenilenmesini ve paranın çekilmesini) iptal et
                return false; 
            }
            
            // Eğer sorun yoksa işleme izin ver
            return true;
        }
    </script>
}