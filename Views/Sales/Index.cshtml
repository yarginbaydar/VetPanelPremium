@model IEnumerable<VetPanelPremium.Models.Invoice>
@{ ViewData["Title"] = "Kasa ve Satış Geçmişi"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark mb-0"><i class="bi bi-wallet2 text-success me-2"></i> Kasa ve Satışlar</h2>
        <p class="text-muted small mt-1">Kliniğin tüm geçmiş satışları ve fatura arşivi</p>
    </div>
    <a asp-action="POS" class="btn btn-success px-4 fw-bold shadow-sm rounded-pill d-flex align-items-center">
        <i class="bi bi-cart-plus fs-5 me-2"></i> Yeni Satış (POS)
    </a>
</div>

<div class="premium-card p-4 border-top border-success border-4 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 premium-datatable">
            <thead class="table-light">
                <tr>
                    <th class="text-secondary py-3">Fatura No</th>
                    <th class="text-secondary py-3">Tarih & Saat</th>
                    <th class="text-secondary py-3">Müşteri Bilgisi</th>
                    <th class="text-secondary py-3 text-center">Ödeme Tipi</th>
                    <th class="text-secondary py-3 text-end">Toplam Tutar</th>
                    <th class="text-secondary py-3 text-center">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @if(Model != null)
                {
                    foreach (var item in Model)
                    {
                        <tr class="border-bottom">
                            <td class="fw-bold text-secondary">#INV-@item.Id.ToString("D5")</td>
                            <td>
                                <span class="d-block fw-bold text-dark">@item.InvoiceDate.ToString("dd MMM yyyy")</span>
                                <small class="text-muted"><i class="bi bi-clock me-1"></i>@item.InvoiceDate.ToString("HH:mm")</small>
                            </td>
                            <td class="fw-bold text-primary">
                                @(item.Owner != null ? item.Owner.FullName : "Genel / Kayıtsız Müşteri")
                            </td>
                            <td class="text-center">
                                @if (item.PaymentMethod == "Nakit") { <span class="badge bg-success shadow-sm px-3 py-2"><i class="bi bi-cash me-1"></i> Nakit</span> }
                                else if (item.PaymentMethod == "Kredi Kartı") { <span class="badge bg-primary shadow-sm px-3 py-2"><i class="bi bi-credit-card me-1"></i> Kart</span> }
                                else { <span class="badge bg-danger shadow-sm px-3 py-2"><i class="bi bi-journal-text me-1"></i> Veresiye</span> }
                            </td>
                            <td class="text-end fw-bold text-success fs-5">@item.TotalAmount.ToString("C")</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-outline-secondary shadow-sm" title="Hızlı Yazdır" onclick="silentPrint('/Sales/Print/@item.Id')">
                                    <i class="bi bi-printer"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function silentPrint(url) {
            // Varsa eski gizli sekmeyi temizle
            var oldIframe = document.getElementById('silent-print-frame');
            if (oldIframe) { oldIframe.remove(); }

            // Kullanıcının göremeyeceği 0 piksellik bir sekme oluştur
            var iframe = document.createElement('iframe');
            iframe.id = 'silent-print-frame';
            // display:none yaparsak bazı tarayıcılar yazdırmayı engeller, o yüzden boyutunu sıfırlıyoruz!
            iframe.style.position = 'absolute';
            iframe.style.width = '0';
            iframe.style.height = '0';
            iframe.style.border = 'none';
            iframe.src = url;
            
            // Gizli sekmeyi sayfaya göm (Arka planda çalışmaya başlar)
            document.body.appendChild(iframe);
        }
    </script>
}