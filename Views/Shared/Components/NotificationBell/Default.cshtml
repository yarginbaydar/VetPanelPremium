<div class="dropdown me-3">
    <button class="btn btn-light position-relative border-0 shadow-sm" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="width: 45px; height: 45px; border-radius: 50%;">
        <i class="bi bi-bell-fill fs-5 @(ViewBag.TotalNotifications > 0 ? "text-primary" : "text-secondary")"></i>
        
        @if (ViewBag.TotalNotifications > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light">
                @ViewBag.TotalNotifications
                <span class="visually-hidden">Okunmamış bildirim</span>
            </span>
        }
    </button>

    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2 p-0" aria-labelledby="notificationDropdown" style="min-width: 300px; overflow: hidden;">
        <li class="bg-primary text-white p-3 fw-bold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-bell me-2"></i> Sistem Bildirimleri</span>
            @if (ViewBag.TotalNotifications > 0)
            {
                <span class="badge bg-light text-primary rounded-pill">@ViewBag.TotalNotifications Yeni</span>
            }
        </li>
        
        <div style="max-height: 300px; overflow-y: auto;">
            @if (ViewBag.TotalNotifications > 0)
            {
                if (ViewBag.ExpiredCount > 0)
                {
                    <li>
                        <a class="dropdown-item p-3 border-bottom d-flex align-items-center text-wrap" href="/Products/Index">
                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-2 me-3"><i class="bi bi-exclamation-octagon-fill"></i></div>
                            <div>
                                <strong class="d-block text-dark">Kritik SKT Alarmı!</strong>
                                <small class="text-muted">Depoda tarihi geçmiş @ViewBag.ExpiredCount ürün var.</small>
                            </div>
                        </a>
                    </li>
                }

                if (ViewBag.ExpiringSoonCount > 0)
                {
                    <li>
                        <a class="dropdown-item p-3 border-bottom d-flex align-items-center text-wrap" href="/Products/Index">
                            <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-2 me-3"><i class="bi bi-exclamation-triangle-fill"></i></div>
                            <div>
                                <strong class="d-block text-dark">Yaklaşan SKT Uyarıları</strong>
                                <small class="text-muted">30 günden az ömrü kalan @ViewBag.ExpiringSoonCount ürün tespit edildi.</small>
                            </div>
                        </a>
                    </li>
                }

                if (ViewBag.CriticalStockCount > 0)
                {
                    <li>
                        <a class="dropdown-item p-3 border-bottom d-flex align-items-center text-wrap" href="/Products/Index">
                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle p-2 me-3"><i class="bi bi-box-seam"></i></div>
                            <div>
                                <strong class="d-block text-dark">Tükenmek Üzere!</strong>
                                <small class="text-muted">Stoğu bitmek üzere olan @ViewBag.CriticalStockCount ürün var.</small>
                            </div>
                        </a>
                    </li>
                }

                if (ViewBag.TodayAppointmentsCount > 0)
                {
                    <li>
                        <a class="dropdown-item p-3 d-flex align-items-center text-wrap" href="/Appointments/Index">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-2 me-3"><i class="bi bi-calendar-event"></i></div>
                            <div>
                                <strong class="d-block text-dark">Bugünün Randevuları</strong>
                                <small class="text-muted">Bugün için bekleyen @ViewBag.TodayAppointmentsCount randevunuz var.</small>
                            </div>
                        </a>
                    </li>
                }
            }
            else
            {
                <li class="p-4 text-center text-muted">
                    <i class="bi bi-check2-circle fs-1 text-success opacity-50 d-block mb-2"></i>
                    <h6 class="fw-bold text-dark mb-1">Harika!</h6>
                    <small>Şu an ilgilenmeniz gereken acil bir bildirim yok. Her şey kontrol altında!</small>
                </li>
            }
        </div>
        <li class="bg-light p-2 text-center border-top">
            <small class="text-muted">VetPanel Akıllı Asistan</small>
        </li>
    </ul>
</div>