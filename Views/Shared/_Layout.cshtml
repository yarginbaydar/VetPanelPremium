@using VetPanelPremium.Data
@inject ApplicationDbContext _context
@{
    var clinicSetting = _context.ClinicSettings.FirstOrDefault();
    var activeClinicName = clinicSetting != null ? clinicSetting.ClinicName : "VetPanel Premium";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @activeClinicName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <div class="wrapper d-flex">
        
        <nav id="sidebar">
            <div class="sidebar-header">
               <h4 class="fw-bold mb-0 text-wrap lh-sm" title="@activeClinicName">
                    <i class="bi bi-hospital text-warning"></i> @activeClinicName
                </h4>
                <small class="text-white-50">Klinik Yönetim Sistemi</small>
            </div>

            <ul class="list-unstyled components">
                <li class="active">
                    <a asp-controller="Home" asp-action="Index"><i class="bi bi-grid-1x2-fill"></i> Ana Sayfa</a>
                </li>
                <li>
                <a asp-controller="Owners" asp-action="Index"><i class="bi bi-people-fill"></i> Müşteriler (CRM)</a>
                </li>
                <li>
                <a asp-controller="Pets" asp-action="Index"><i class="bi bi-box2-heart-fill"></i> Hastalar (EMR)</a>
                </li>
               <li>
                <a asp-controller="Appointments" asp-action="Index"><i class="bi bi-calendar-check-fill"></i> Randevu Takvimi</a>
                </li>
                <li>
                <a asp-controller="Sales" asp-action="Index"><i class="bi bi-wallet2"></i> Kasa ve Satış (POS)</a>
                </li>
                <li>
                <a asp-controller="Sales" asp-action="Debtors"><i class="bi bi-journal-bookmark-fill"></i> Veresiye Defteri</a>
                </li>
                <li>
                <a asp-controller="Products" asp-action="Index"><i class="bi bi-box-seam-fill"></i> Stok ve Ürünler</a>
                </li>
                <li>
                <a asp-controller="ClinicSettings" asp-action="Index"><i class="bi bi-gear-fill"></i> Klinik Ayarları</a>
                </li>
            </ul>
        </nav>

        <div id="content">
            
            <div class="topbar d-flex justify-content-between align-items-center">
                
                <div class="quick-actions">
                    <div class="dropdown">
                        <button class="btn btn-primary fw-bold shadow-sm rounded-pill px-4 border-0 d-flex align-items-center" type="button" id="quickActionDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="height: 45px;">
                            <i class="bi bi-lightning-charge-fill text-warning me-2 fs-5"></i> Hızlı İşlem
                        </button>
                        <ul class="dropdown-menu shadow-lg border-0 mt-3 rounded-4" aria-labelledby="quickActionDropdown" style="min-width: 220px;">
                            <li><h6 class="dropdown-header text-primary fw-bold"><i class="bi bi-stars me-1"></i> Kısayollar</h6></li>
                            
                            <li><a class="dropdown-item py-2 fw-bold text-dark" asp-controller="Appointments" asp-action="Create"><i class="bi bi-calendar-plus text-primary me-2"></i> Yeni Randevu</a></li>
                            <li><a class="dropdown-item py-2 fw-bold text-dark" asp-controller="Owners" asp-action="Create"><i class="bi bi-person-plus text-success me-2"></i> Yeni Müşteri</a></li>
                            <li><a class="dropdown-item py-2 fw-bold text-dark" asp-controller="Pets" asp-action="Create"><i class="bi bi-box2-heart text-danger me-2"></i> Yeni Hasta (Pet)</a></li>
                            
                            <li><hr class="dropdown-divider mx-3"></li>
                            
                            <li><a class="dropdown-item py-2 fw-bold text-dark" asp-controller="Sales" asp-action="Index"><i class="bi bi-cart-plus text-warning me-2"></i> Kasaya Geç (Satış)</a></li>
                        </ul>
                    </div>
                </div>

                <div class="user-profile d-flex align-items-center">
                    
                    @await Component.InvokeAsync("NotificationBell")
                    
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="https://ui-avatars.com/api/?name=@User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value&background=0d6efd&color=fff" class="rounded-circle me-2 shadow-sm border border-2 border-white" width="45" alt="User">
                            
                            <div class="d-none d-md-block text-start me-2">
                                <strong class="d-block lh-1 text-dark">@User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value</strong>
                                <small class="text-muted fw-bold">Başhekim / Admin</small>
                            </div>
                        </a>
                        
                        <ul class="dropdown-menu dropdown-menu-end text-small shadow-lg border-0 mt-3 rounded-4" aria-labelledby="dropdownUser" style="min-width: 250px;">
                            <li class="px-4 py-3 border-bottom bg-light bg-opacity-50 rounded-top-4">
                                <span class="d-block small text-muted mb-1">Aktif Oturum:</span>
                                <strong class="d-block text-primary fs-6"><i class="bi bi-hospital text-primary me-2"></i> @activeClinicName</strong>
                            </li>
                            
                            <li><a class="dropdown-item px-4 py-2 mt-2 fw-bold text-secondary" asp-controller="Auth" asp-action="Profile"><i class="bi bi-person-vcard me-2 text-primary"></i> Profilimi Düzenle</a></li>
                            <li><a class="dropdown-item px-4 py-2 fw-bold text-secondary" asp-controller="ClinicSettings" asp-action="Index"><i class="bi bi-gear-fill me-2 text-warning"></i> Sistem Ayarları</a></li>
                            
                            <li><hr class="dropdown-divider mx-3"></li>
                            
                            <li><a class="dropdown-item px-4 py-2 mb-1 fw-bold text-danger" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i> Güvenli Çıkış Yap</a></li>
                        </ul>
                    </div>
                </div>
                
            </div>

            <div class="main-body">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
            
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.premium-datatable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/tr.json'
                },
                pageLength: 10,
                lengthMenu: [[10, 25, 50, -1], [10, 25, 50, "Tümü"]],
                order: [], 
                stateSave: true 
            });
        });
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>